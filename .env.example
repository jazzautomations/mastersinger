# ──────────────────────────────────────────────────────────────────────────
# MasterSinger — environment variables
# Copy to `.env` (local) and set the same keys in Vercel → Project → Settings →
# Environment Variables. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase (public, safe for the browser bundle) ──
# Project URL + anon key. Found in Supabase → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...

# ── Supabase (SERVER ONLY — never expose to the browser) ──
# Service role key, used by /api functions to validate JWTs and write
# subscription rows past RLS. Found in Supabase → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...

# ── Asaas (SERVER ONLY) ──
# API access token. Found in Asaas → Configurações → API → Gerar token.
# Sandbox starts with $aac... ; production with $aat... (or the live token).
ASAAS_ACCESS_TOKEN=$aac...
# Base URL: sandbox https://sandbox.asaas.com/api/v3 | prod https://www.asaas.com/api/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# ── Asaas webhook (optional but recommended) ──
# A shared secret you invent and also set on the webhook config in Asaas.
# We additionally re-verify every payment by fetching it from the Asaas API.
ASAAS_WEBHOOK_SECRET=invent-a-long-random-string
